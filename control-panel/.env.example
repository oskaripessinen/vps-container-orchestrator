NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY

DEPLOY_REPO_OWNER=YOUR_DEPLOY_REPO_OWNER
DEPLOY_REPO_NAME=vps-container-orchestrator
# Optional alternative for owner/name pair:
# DEPLOY_REPOSITORY=YOUR_DEPLOY_REPO_OWNER/vps-container-orchestrator
DEPLOY_WORKFLOW_FILE=deploy-app-from-ui.yml
DEPLOY_WORKFLOW_REF=main
DEPLOY_GITHUB_TOKEN=YOUR_DEPLOY_WORKFLOW_DISPATCH_TOKEN
# Optional alias for deploy token:
# GITHUB_TOKEN=YOUR_DEPLOY_WORKFLOW_DISPATCH_TOKEN

# VPS metrics API (for real-time server/container stats in dashboard)
VPS_METRICS_URL=https://metrics.example.com/api/v1/stats
VPS_METRICS_TOKEN=YOUR_VPS_METRICS_API_TOKEN
# Optional timeout for control-panel -> metrics API call
# VPS_METRICS_TIMEOUT_MS=6000
